    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    <script>
        (function () {
            var modalStorageKey = 'duzeyPromoInfoModalDismissedUntil';
            var modalCookieKey = 'duzeyPromoInfoModalDismissed';
            var dismissDays = 30;

            function hasSeenPromoInfoModal() {
                var now = Date.now();
                try {
                    var storedUntil = parseInt(window.localStorage.getItem(modalStorageKey), 10);
                    if (!isNaN(storedUntil) && storedUntil > now) {
                        return true;
                    }
                } catch (error) {
                    // Fall back to cookie below when localStorage is blocked.
                }

                return document.cookie.split(';').some(function (cookie) {
                    return cookie.trim().indexOf(modalCookieKey + '=1') === 0;
                });
            }

            function markPromoInfoModalSeen() {
                var expiresAt = Date.now() + (dismissDays * 24 * 60 * 60 * 1000);
                try {
                    window.localStorage.setItem(modalStorageKey, expiresAt.toString());
                } catch (error) {
                    // Cookie still covers normal navigation if localStorage is unavailable.
                }

                document.cookie = modalCookieKey + '=1; Max-Age=' + (dismissDays * 24 * 60 * 60) + '; Path=/; SameSite=Lax';

                if (location.hostname === 'duzeypromosyon.com' || location.hostname === 'www.duzeypromosyon.com') {
                    document.cookie = modalCookieKey + '=1; Max-Age=' + (dismissDays * 24 * 60 * 60) + '; Path=/; Domain=.duzeypromosyon.com; SameSite=Lax';
                }
            }

            function showPromoInfoModal() {
                var modalElement = document.getElementById('promoInfoModal');
                if (!modalElement || typeof bootstrap === 'undefined' || !bootstrap.Modal) {
                    return;
                }

                if (hasSeenPromoInfoModal()) {
                    return;
                }

                var modal = new bootstrap.Modal(modalElement);
                modalElement.addEventListener('hide.bs.modal', markPromoInfoModalSeen, { once: true });
                modalElement.addEventListener('hidden.bs.modal', markPromoInfoModalSeen, { once: true });
                modal.show();
            }

            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', showPromoInfoModal);
            } else {
                showPromoInfoModal();
            }
        })();

        (function () {
            function updateProductImageState(image) {
                var imageWrap = image.closest('.product-image');
                if (!imageWrap) {
                    return;
                }

                imageWrap.classList.remove('is-loading');

                if (image.naturalWidth > 0) {
                    imageWrap.classList.add('is-loaded');
                    imageWrap.classList.remove('is-error');
                } else {
                    imageWrap.classList.add('is-error');
                    imageWrap.classList.remove('is-loaded');
                }
            }

            function bindProductImageStates() {
                var images = document.querySelectorAll('.product-image img');

                images.forEach(function (image) {
                    if (image.complete) {
                        updateProductImageState(image);
                        return;
                    }

                    image.addEventListener('load', function () {
                        updateProductImageState(image);
                    }, { once: true });

                    image.addEventListener('error', function () {
                        updateProductImageState(image);
                    }, { once: true });
                });
            }

            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', bindProductImageStates);
            } else {
                bindProductImageStates();
            }
        })();

        (function () {
            function normalizeText(value) {
                return (value || '')
                    .toLocaleLowerCase('tr-TR')
                    .replace(/ğ/g, 'g')
                    .replace(/ü/g, 'u')
                    .replace(/ş/g, 's')
                    .replace(/ı/g, 'i')
                    .replace(/ö/g, 'o')
                    .replace(/ç/g, 'c');
            }

            function bindCategoryMenuSearch() {
                var menu = document.querySelector('.category-menu');
                if (!menu) {
                    return;
                }

                var input = menu.querySelector('[data-category-search]');
                var empty = menu.querySelector('[data-category-empty]');
                var columns = Array.prototype.slice.call(menu.querySelectorAll('.category-menu-column'));

                if (!input || !columns.length) {
                    return;
                }

                input.addEventListener('click', function (event) {
                    event.stopPropagation();
                });

                input.addEventListener('input', function () {
                    var query = normalizeText(input.value);
                    var totalVisible = 0;

                    columns.forEach(function (column) {
                        var title = column.querySelector('.category-menu-title');
                        var titleMatches = title && normalizeText(title.textContent).indexOf(query) >= 0;
                        var links = Array.prototype.slice.call(column.querySelectorAll('.dropdown-item'));
                        var visibleInColumn = 0;

                        links.forEach(function (link) {
                            var isVisible = !query || titleMatches || normalizeText(link.textContent).indexOf(query) >= 0;
                            link.hidden = !isVisible;

                            if (isVisible) {
                                visibleInColumn += 1;
                            }
                        });

                        column.hidden = visibleInColumn === 0;
                        totalVisible += visibleInColumn;
                    });

                    if (empty) {
                        empty.hidden = totalVisible > 0;
                    }
                });
            }

            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', bindCategoryMenuSearch);
            } else {
                bindCategoryMenuSearch();
            }
        })();
    </script>
    @RenderSection("scripts", required: false)
</body>
</html>
