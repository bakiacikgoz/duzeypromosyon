@model duzeypromosyonn.Models.Canta
<section class="admin-card admin-form-card">
    <h1>@ViewBag.Title</h1>
    @using (Html.BeginForm(null, null, FormMethod.Post, new { enctype = "multipart/form-data" }))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(x => x.Id)
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })
        <div class="row g-3">
            <div class="col-md-8">
                @Html.LabelFor(x => x.Baslik, "Başlık", new { @class = "form-label" })
                @Html.TextBoxFor(x => x.Baslik, new { @class = "form-control" })
                @Html.ValidationMessageFor(x => x.Baslik, "", new { @class = "text-danger" })
            </div>
            <div class="col-md-4">
                @Html.LabelFor(x => x.UrunKodu, "Ürün kodu", new { @class = "form-label" })
                @Html.TextBoxFor(x => x.UrunKodu, new { @class = "form-control" })
                @Html.ValidationMessageFor(x => x.UrunKodu, "", new { @class = "text-danger" })
            </div>
            <div class="col-md-4">
                @Html.LabelFor(x => x.Fiyat, "Fiyat", new { @class = "form-label" })
                @Html.TextBoxFor(x => x.Fiyat, new { @class = "form-control", type = "number", step = "0.01" })
                @Html.ValidationMessageFor(x => x.Fiyat, "", new { @class = "text-danger" })
            </div>
            <div class="col-12">
                @Html.LabelFor(x => x.Aciklama, "Açıklama", new { @class = "form-label" })
                @Html.TextAreaFor(x => x.Aciklama, 7, 30, new { @class = "form-control" })
            </div>
            <div class="col-12">
                <label class="form-label" for="files">Görseller</label>
                <input class="form-control" type="file" id="files" name="files" multiple accept="image/*" />
            </div>
        </div>
        <button class="btn btn-primary mt-3" type="submit">Kaydet</button>
        <a class="btn btn-link mt-3" href="@Url.Action("Index")">İptal</a>
    }

    @if (Model.ImageUrls != null && Model.ImageUrls.Any())
    {
        <hr />
        <h2>Yüklü görseller</h2>
        <div class="admin-image-grid">
            @foreach (var image in Model.ImageUrls)
            {
                <div>
                    <img src="@Url.Content(image)" alt="@Model.Baslik" />
                    @using (Html.BeginForm("RemoveImage", "AdminCanta", new { id = Model.Id, imageUrl = image }, FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()
                        <button class="btn btn-sm btn-outline-danger" type="submit">Görseli sil</button>
                    }
                </div>
            }
        </div>
    }
</section>
